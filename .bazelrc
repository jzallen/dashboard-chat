# ─── Build ────────────────────────────────────────────────────────────────────
build --disk_cache=~/.cache/bazel-disk
build --experimental_strict_action_env
build --workspace_status_command=tools/workspace_status.sh
# --stamp enables expand_template.stamp_substitutions in tools/version_layer.bzl.
# Cache hygiene: STABLE_* keys only invalidate the small version_layer tar,
# not dependent actions, so day-to-day builds stay incremental.
build --stamp
# Disk-cache + install-base + action-cache GC: cap unbounded growth that has
# caused inode exhaustion under multi-polecat concurrency (see dc-99b).
# Size cap (15G) bumped above the conservative 5G after 2026-05-20 disk audit:
# this disk cache is now the only build cache (BuildBuddy remote removed below),
# so the larger cap trades disk for fewer cold rebuilds. Adjust down if disk
# pressure returns.
# Stale per-workspace output_bases (~/.cache/bazel/_bazel_*/<hash>/) are NOT
# GC'd by these flags — clean orphans manually. rules_oci writes blobs with
# read-only perms (OCI integrity), so plain `rm -rf` fails; chmod first:
#   ACTIVE=$(bazel info output_base 2>/dev/null | xargs basename)
#   for d in ~/.cache/bazel/_bazel_node/*/; do
#     n=$(basename "$d")
#     case "$n" in install|cache|"$ACTIVE") continue;; esac
#     chmod -R u+w "$d" 2>/dev/null; rm -rf "$d"
#   done
build --experimental_disk_cache_gc_max_size=15G
build --experimental_disk_cache_gc_max_age=7d
build --experimental_disk_cache_gc_idle_delay=2m
build --experimental_install_base_gc_max_age=3d
build --experimental_action_cache_gc_max_age=7d

# ─── Test ─────────────────────────────────────────────────────────────────────
test --test_output=errors
test --test_verbose_timeout_warnings
test --local_test_jobs=HOST_CPUS*1.5
test --experimental_reuse_sandbox_directories
# Pass through PATH so no-sandbox lint targets (sh_test) can find uv and npm
test --action_env=PATH

# ─── E2E Config ──────────────────────────────────────────────────────────────
test:e2e --sandbox_writable_path=/var/run/docker.sock
test:e2e --test_output=all
test:e2e --test_timeout=300

# ─── CI ───────────────────────────────────────────────────────────────────────
build:ci --disk_cache=~/.cache/bazel-disk
build:ci --experimental_disk_cache_gc_max_size=15G
build:ci --experimental_disk_cache_gc_max_age=7d
build:ci --experimental_disk_cache_gc_idle_delay=2m
build:ci --experimental_install_base_gc_max_age=3d
build:ci --experimental_action_cache_gc_max_age=7d
test:ci --test_output=all
test:ci --local_test_jobs=HOST_CPUS
test:ci --experimental_reuse_sandbox_directories

# ─── Platform: Linux ─────────────────────────────────────────────────────────
build:linux --platforms=@platforms//os:linux

# ─── Platform: macOS ─────────────────────────────────────────────────────────
build:macos --platforms=@platforms//os:macos

# ─── Remote cache (BuildBuddy) — DISABLED ─────────────────────────────────────
# Removed: on the anonymous free tier the cross-clone sharing only amounted to
# the node-deps cache (marginal vs. the local --disk_cache above), and anonymous
# access is being deprecated (builds emitted a FAILED_PRECONDITION banner). The
# local --disk_cache carries day-to-day incremental builds on its own.
#
# To re-enable (worth it only if concurrent gastown clones do redundant cold
# builds — and only with an API key, not anonymously): get a free key at
# https://app.buildbuddy.io/settings/api-keys, put it in .bazelrc.user
# (gitignored, try-import below), and restore:
#   build --bes_results_url=https://app.buildbuddy.io/invocation/
#   build --bes_backend=grpcs://remote.buildbuddy.io
#   build --remote_cache=grpcs://remote.buildbuddy.io
#   build --remote_timeout=3600
#   build --remote_local_fallback   # don't fail builds if unreachable

# ─── Local user overrides (gitignored) ───────────────────────────────────────
# Put secrets and per-machine tweaks here. See .bazelrc.user.example.
try-import %workspace%/.bazelrc.user
