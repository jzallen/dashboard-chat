#!/bin/bash
set -euo pipefail

# Auto-fix Python formatting and lint issues (does NOT stage — see note at bottom)
(cd backend && uv run ruff format . && uv run ruff check --fix .)

# Auto-fix JS/TS lint issues (scoped to match Bazel lint targets: //reverse-proxy:lint, //agent:lint)
npx eslint --fix frontend/src agent/

# Verify nothing unfixable remains (same commands as //reverse-proxy:lint, //agent:lint, //backend:lint)
npx eslint frontend/src agent/
(cd backend && uv run ruff check . && uv run ruff format --check .)

# Report auto-fixes WITHOUT staging them. The previous hook ran `git add -u`, which
# silently swept *every* modified tracked file into the commit. Leaving fixes
# unstaged keeps each commit scoped to exactly what was deliberately staged.
if ! git diff --quiet; then
echo
echo "──────────────────────────────────────────────────────────────────────────────"
echo "⚠  Unstaged changes after lint/format auto-fix (NOT included in this commit):"
echo
git --no-pager diff --stat
echo
echo "  For Claude: before pushing / 'gt mq submit', commit these as a follow-up:"
echo "      git diff                                       # review the fixes"
echo "      git add -u && git commit -m 'style: lint/format auto-fixes'"
echo "──────────────────────────────────────────────────────────────────────────────"
fi
