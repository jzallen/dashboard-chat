# Lint staged files (ruff for Python, ESLint for TypeScript)
npx lint-staged

# Secret scanning on staged files
# Uses detect-secrets with a baseline file that whitelists known dev defaults
# (minioadmin, dev-token-static, dashboard_secret, etc.)
STAGED=$(git diff --cached --name-only --diff-filter=d)
if [ -n "$STAGED" ]; then
  echo "$STAGED" | xargs uv run --project backend detect-secrets-hook --baseline .secrets.baseline 2>/dev/null
fi

# Check for merge conflict markers left in staged files
CONFLICT_FILES=$(git diff --cached --name-only | xargs grep -l '<''<<<<<< ' 2>/dev/null || true)
if [ -n "$CONFLICT_FILES" ]; then
  echo "Error: Merge conflict markers found in:"
  echo "$CONFLICT_FILES"
  exit 1
fi

# Check for large files (>500KB) to prevent accidental binary/data commits
git diff --cached --name-only --diff-filter=d | while IFS= read -r f; do
  [ -z "$f" ] && continue
  size=$(git cat-file -s ":$f" 2>/dev/null || echo 0)
  if [ "$size" -gt 512000 ]; then
    echo "Error: $f is too large ($((size / 1024))KB > 500KB)"
    exit 1
  fi
done
