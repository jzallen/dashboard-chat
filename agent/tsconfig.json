{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "baseUrl": "..",
    "paths": {
      "@/raqb": ["reverse-proxy/src/lib/raqb"],
      "@shared/*": ["shared/*"]
    }
  },
  "include": ["*.ts", "lib/**/*.ts", "../shared/**/*.ts"]
}
