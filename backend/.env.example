# Database
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=dashboard_secret
POSTGRES_DB=dashboard_chat
DATABASE_URL=postgresql+asyncpg://dashboard:dashboard_secret@localhost:5432/dashboard_chat

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Debug mode
DEBUG=true

# Storage (MinIO for local dev, s3 for production)
STORAGE_TYPE=minio
STORAGE_BUCKET=dashboard-chat.datalake
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
