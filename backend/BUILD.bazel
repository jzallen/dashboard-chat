# ─── Scripts ─────────────────────────────────────────────────────────────────

py_library(
    name = "scripts",
    srcs = glob(["scripts/**/*.py"]),
    imports = ["."],
    visibility = ["//visibility:public"],
    deps = [
        ":core",
        ":models",
        ":repositories",
        "@pip//boto3",
        "@pip//sqlalchemy",
        "@pip//uuid_utils",
    ],
)

# ─── Entrypoint Binary ───────────────────────────────────────────────────────

py_binary(
    name = "server",
    srcs = ["server.py"],
    deps = [":app", ":scripts"],
    visibility = ["//visibility:public"],
)

# ─── OCI Image ───────────────────────────────────────────────────────────────

version_layer(
    name = "version_layer",
    image_tag = "dashboard-chat/api:bazel",
)

oci_image(
    name = "image",
    base = "@python_3_11_slim",
    tars = py_image_layer(
        name = "py_layer",
        binary = ":server",
    ) + [":version_layer"],
    entrypoint = ["/backend/server"],
    exposed_ports = ["8000"],
    tags = ["manual"],
    visibility = ["//visibility:public"],
)

oci_load(
    name = "image_tar",
    image = ":image",
    repo_tags = ["dashboard-chat/api:bazel"],
    tags = ["manual"],
    visibility = ["//visibility:public"],
)
