load("@aspect_rules_py//py:defs.bzl", "py_image_layer")
load("@rules_oci//oci:defs.bzl", "oci_image", "oci_load")
load("@rules_python//python:py_binary.bzl", "py_binary")
load("@rules_python//python:py_library.bzl", "py_library")
load("@rules_shell//shell:sh_test.bzl", "sh_test")
load("//tools:version_layer.bzl", "version_layer")
load(":pytest_tests.bzl", "pytest_tests")

# ─── Layered py_library Targets ──────────────────────────────────────────────
#
# Layer 0: exceptions (DomainException base — zero deps)
# Layer 0: core (config, database, types — sqlalchemy, pydantic_settings)
# Layer 0: utils (pagination, csv_parser, column_profiler, etc.)
# Layer 0: models (no app imports beyond core)
# Layer 1: plugins (core, exceptions), repos (core, utils)
# Layer 2: auth (repos — core transitive)
# Layer 3: use_cases (models, plugins, repos, auth, exceptions — core transitive)
# Layer 4: controllers (use_cases — core transitive)
# Layer 5: app (main.py + routers/ — depends on everything)

py_library(
    name = "exceptions",
    srcs = [
        "app/use_cases/__init__.py",
        "app/use_cases/exceptions.py",
    ],
    imports = ["."],
    visibility = ["//visibility:public"],
    deps = [
        "@pip//returns",
    ],
)

py_library(
    name = "core",
    srcs = [
        "app/__init__.py",
        "app/config.py",
        "app/database.py",
        "app/types.py",
        "app/version.py",
    ] + glob(["app/infra/**/*.py"]),
    imports = ["."],
    visibility = ["//visibility:public"],
    deps = [
        "@pip//aiosqlite",
        "@pip//asyncpg",
        "@pip//ibis_framework",
        "@pip//pydantic_settings",
        "@pip//sqlalchemy",
        "@pip//uuid_utils",
    ],
)

py_library(
    name = "utils",
    srcs = glob(["app/utils/**/*.py"]),
    imports = ["."],
    visibility = ["//visibility:public"],
    deps = [
        "@pip//duckdb",
        "@pip//ibis_framework",
        "@pip//pandas",
        "@pip//pyarrow",
    ],
)

py_library(
    name = "models",
    srcs = glob(["app/models/**/*.py"]),
    imports = ["."],
    visibility = ["//visibility:public"],
    deps = [
        ":core",
        "@pip//pydantic",
        "@pip//sqlalchemy",
    ],
)

py_library(
    name = "plugins",
    srcs = glob(["app/plugins/**/*.py"]),
    imports = ["."],
    visibility = ["//visibility:public"],
    deps = [
        ":core",
        ":exceptions",
        ":utils",
        "@pip//fhir_resources",
        "@pip//httpx",
        "@pip//openpyxl",
        "@pip//pandas",
        "@pip//pydantic",
        "@pip//pyyaml",
    ],
)

py_library(
    name = "repositories",
    srcs = glob(["app/repositories/**/*.py"]),
    imports = ["."],
    visibility = ["//visibility:public"],
    deps = [
        ":core",
        ":utils",
        "@pip//boto3",
        "@pip//duckdb",
        "@pip//ibis_framework",
        "@pip//pyarrow",
        "@pip//pyarrow_hotfix",
        "@pip//sqlalchemy",
    ],
)

py_library(
    name = "auth",
    srcs = glob(["app/auth/**/*.py"]),
    imports = ["."],
    visibility = ["//visibility:public"],
    deps = [
        ":repositories",
        "@pip//bcrypt",
        "@pip//cryptography",
        "@pip//httpx",
        "@pip//pyjwt",
    ],
)

py_library(
    name = "use_cases",
    srcs = glob(
        ["app/use_cases/**/*.py"],
        exclude = [
            "app/use_cases/__init__.py",
            "app/use_cases/exceptions.py",
        ],
    ),
    imports = ["."],
    visibility = ["//visibility:public"],
    deps = [
        ":auth",
        ":exceptions",
        ":models",
        ":plugins",
        ":repositories",
        "@pip//aiodocker",
        "@pip//boto3",
        "@pip//duckdb",
        "@pip//ibis_framework",
        "@pip//packaging",
        "@pip//pandas",
        "@pip//pydantic",
        "@pip//pyyaml",
        "@pip//returns",
    ],
)

py_library(
    name = "controllers",
    srcs = glob(["app/controllers/**/*.py"]),
    imports = ["."],
    visibility = ["//visibility:public"],
    deps = [
        ":exceptions",
        ":use_cases",
        "@pip//fastapi",
        "@pip//returns",
    ],
)

# Full app — main.py + routers (depends on everything)
py_library(
    name = "app",
    srcs = ["app/main.py"] + glob(["app/routers/**/*.py"]),
    imports = ["."],
    visibility = ["//visibility:public"],
    deps = [
        ":auth",
        ":controllers",
        ":exceptions",
        ":use_cases",
        "@pip//fastapi",
        "@pip//python_multipart",
        "@pip//uvicorn",
    ],
)

# ─── Test Infrastructure ─────────────────────────────────────────────────────

py_library(
    name = "test_lib",
    srcs = glob(["tests/**/__init__.py"]) + [
        "tests/conftest.py",
        "tests/uuidv7_fixtures.py",
    ],
    imports = ["."],
    data = ["pyproject.toml"],
    deps = [
        ":core",
        "@pip//boto3",
        "@pip//moto",
        "@pip//pytest",
        "@pip//pytest_asyncio",
    ],
)

# ─── Lint ────────────────────────────────────────────────────────────────────

sh_test(
    name = "lint",
    srcs = ["lint_test.sh"],
    data = [
        "pyproject.toml",
    ] + glob([
        "app/**/*.py",
        "tests/**/*.py",
    ]),
    tags = ["no-sandbox", "lint"],
    size = "small",
)

