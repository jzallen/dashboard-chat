# ─── OCI Image ───────────────────────────────────────────────────────────────

genrule(
    name = "nginx_conf_layer",
    srcs = ["nginx.conf"],
    outs = ["nginx_conf.tar"],
    cmd = """
        mkdir -p $$TMPDIR/etc/nginx/conf.d && \
        cp $(location nginx.conf) $$TMPDIR/etc/nginx/conf.d/default.conf && \
        tar -cf $(OUTS) -C $$TMPDIR etc
    """,
    tags = ["no-sandbox", "manual"],
)

version_layer(
    name = "version_layer",
    image_tag = "dashboard-chat/reverse-proxy:bazel",
)

genrule(
    name = "entrypoint_layer",
    srcs = ["docker-entrypoint.sh"],
    outs = ["entrypoint.tar"],
    cmd = """
        staging=$$(mktemp -d) && \
        mkdir -p $$staging/usr/local/bin && \
        cp $(location docker-entrypoint.sh) $$staging/usr/local/bin/dashboard-entrypoint.sh && \
        chmod +x $$staging/usr/local/bin/dashboard-entrypoint.sh && \
        tar -cf $(OUTS) -C $$staging usr && \
        rm -rf $$staging
    """,
    tags = ["no-sandbox", "manual"],
)

# reverse-proxy is a pure routing/coordination image (ADR-047): nginx conf +
# build identity + entrypoint. It carries NO frontend assets — web-ssr owns and
# serves build/client. The entrypoint still writes /usr/share/nginx/html/_meta.json
# (its own build identity, dc-1k8); nginx serves that one file from its static root.
oci_image(
    name = "image",
    base = "@nginx_alpine",
    tars = [
        ":nginx_conf_layer",
        ":version_layer",
        ":entrypoint_layer",
    ],
    entrypoint = ["/usr/local/bin/dashboard-entrypoint.sh"],
    exposed_ports = ["80"],
    tags = ["manual"],
    visibility = ["//visibility:public"],
)

oci_load(
    name = "image_tar",
    image = ":image",
    repo_tags = ["dashboard-chat/reverse-proxy:bazel"],
    tags = ["manual"],
    visibility = ["//visibility:public"],
)

# ─── SSR OCI Image (web-ssr) ─────────────────────────────────────────────────
#
# Hono + RRv7 SSR runtime. Mirrors agent/BUILD.bazel:56-104's pattern:
# esbuild bundles `ssr.ts` to a single ESM `ssr.mjs`, then oci_image stacks
# the bundle + version layer on `@node_20_slim`. The genrule additionally
# invokes `vite build` so the RRv7 plugin emits the SSR server bundle that
# `ssr.ts` imports at runtime (`./build/server/index.js`).
#
# Layer layout inside ssr_dist.tar:
#   /app/frontend/ssr.mjs           — esbuild output (Hono entry)
#   /app/frontend/build/server/...  — vite build SSR output (RRv7 plugin)
#   /app/frontend/build/client/...  — vite build client output; web-ssr serves these
#                                     statically at /assets/* (ADR-047). This is now the
#                                     SINGLE source of frontend assets — the reverse-proxy
#                                     image no longer carries a copy.
#
# This is the ONLY `react-router build` in the repo (ADR-047). `rm -rf build`
# runs first so the output contains EXACTLY one set of content-hashed assets:
# the `no-sandbox` tag means the genrule shares the source `frontend/build/`
# dir across runs, so without the clean it would accumulate stale hashed
# chunks (e.g. multiple AuthContext-*.js) and Bazel's disk cache could then
# tar up ghost variants — the determinism half of the 404 root cause.
#
# Per DWD-5 (frontend-coexistence). Per DESIGN application-architecture.md §6.2.

genrule(
    name = "ssr_dist",
    srcs = [
        ":sources",
        ":app_framework",
        "ssr.ts",
        "//:.env",
    ],
    outs = ["ssr_dist.tar"],
    # `--banner:js` polyfills CommonJS `require` inside the ESM bundle so any
    # transitively-bundled CJS deps can still load Node built-ins at runtime —
    # same rationale as agent/BUILD.bazel:69-75.
    #
    # The staging tree ($$TMPDIR/app) is wiped at the top of every run. Bazel
    # reuses $$TMPDIR across no-sandbox genrule executions, so without this the
    # `cp -r build/server <dir>` lines nest into an existing dir (server/server)
    # and a prior run's content-hashed assets persist alongside the new ones —
    # producing a tar whose SSR HTML references client hashes the served
    # build/client no longer contains (the /assets/* 404 class). One clean
    # `react-router build` is internally consistent; the corruption came purely
    # from staging-dir accumulation.
    cmd = """
        set -a && . .env && set +a && \
        cd frontend && \
        rm -rf build && \
        VITE_CHAT_URL=/worker VITE_STREAM_API_KEY=$${STREAM_API_KEY:-} NODE_ENV=production npx react-router build && \
        rm -rf ../$$TMPDIR/app && \
        mkdir -p ../$$TMPDIR/app/frontend/build && \
        npx esbuild ssr.ts --bundle --platform=node --format=esm \
            --banner:js="import{createRequire}from'module';const require=createRequire(import.meta.url);" \
            --outfile=../$$TMPDIR/app/frontend/ssr.mjs && \
        cp -r build/server ../$$TMPDIR/app/frontend/build/server && \
        cp -r build/client ../$$TMPDIR/app/frontend/build/client && \
        tar -cf - -C ../$$TMPDIR app > ../$(OUTS)
    """,
    tags = ["no-sandbox", "manual"],
    visibility = ["//visibility:public"],
)

version_layer(
    name = "ssr_version_layer",
    image_tag = "dashboard-chat/web-ssr:bazel",
)

oci_image(
    name = "ssr_image",
    base = "@node_20_slim",
    tars = [
        ":ssr_dist",
        ":ssr_version_layer",
    ],
    workdir = "/app",
    entrypoint = ["node", "frontend/ssr.mjs"],
    exposed_ports = ["3001"],
    tags = ["manual"],
    visibility = ["//visibility:public"],
)

oci_load(
    name = "ssr_image_tar",
    image = ":ssr_image",
    repo_tags = ["dashboard-chat/web-ssr:bazel"],
    tags = ["manual"],
    visibility = ["//visibility:public"],
)
