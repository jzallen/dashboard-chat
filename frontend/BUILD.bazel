# Aggregate target for Vite production build
js_library(
    name = "sources",
    srcs = [],
    visibility = ["//visibility:public"],
    deps = [
        ":app_shell",
        ":config",
        ":core_auth",
        ":core_chat",
        ":core_datacatalog",
        ":core_toolcalls",
        ":lib",
        ":ui",
    ],
)

# ─── Vite Build ──────────────────────────────────────────────────────────────

genrule(
    name = "dist",
    srcs = [
        ":sources",
        "//:.env",
    ],
    outs = ["dist.tar"],
    cmd = """
        set -a && . .env && set +a && \
        cd frontend && \
        VITE_CHAT_URL=/worker VITE_STREAM_API_KEY=$${STREAM_API_KEY:-} NODE_ENV=production npx vite build --outDir ../$$TMPDIR/dist --emptyOutDir && \
        tar -cf - -C ../$$TMPDIR dist > ../$(OUTS)
    """,
    tags = ["no-sandbox", "manual"],
    visibility = ["//visibility:public"],
)

