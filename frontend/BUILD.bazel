js_library(
    name = "ui",
    srcs = glob(
        [
            "src/ui/**/*.ts",
            "src/ui/**/*.tsx",
            "src/ui/**/*.css",
        ],
        exclude = ["src/ui/**/*.test.ts", "src/ui/**/*.test.tsx"],
