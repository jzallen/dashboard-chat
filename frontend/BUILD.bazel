# RRv7 framework-mode tree (ADR-034). Includes root.tsx, routes.ts, and the
# per-route modules under app/routes/. Without this target, the vite/Bazel
# build runs against an incomplete sandbox view and silently strips loader
# exports from the SSR bundle (`hasLoader: false` in the route manifest),
# breaking every cold deep-link acceptance scenario that depends on
# server-side scope resolution. The runtime SSR entry point `ssr.ts` AND
# the framework-mode build config are also declared here so esbuild + the
# RRv7 plugin see them as hermetic inputs.
js_library(
    name = "app_framework",
    srcs = glob(
        [
            "app/**/*.ts",
            "app/**/*.tsx",
            "ssr.ts",
        ],
        exclude = [
            "app/**/*.test.ts",
            "app/**/*.test.tsx",
        ],
    ),
    deps = [":node_modules"],
)

# Aggregate target for Vite production build
js_library(
    name = "sources",
    srcs = [],
    visibility = ["//visibility:public"],
    deps = [
        ":app_framework",
        ":app_shell",
        ":config",
        ":core_auth",
        ":core_chat",
        ":core_datacatalog",
        ":core_toolcalls",
        ":lib",
        ":ui",
    ],
)

# ─── Vite / RRv7 Build ───────────────────────────────────────────────────────
#
# There is exactly ONE `react-router build` in this file (ADR-047). It lives in
# the `:ssr_dist` genrule below. The relic `:dist` genrule + nginx `:assets_layer`
# (which produced a second, independently-hashed copy of build/client for the
# reverse-proxy to serve statically) are GONE: a second build could never be
# guaranteed to agree with web-ssr's content hashes, which is the root cause of
# the `/assets/*` 404 class (ADR-047). web-ssr now owns and serves build/client.

