{
  "name": "dashboard-chat",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": ["frontend", "worker", "shared/chat"],
  "scripts": {
    "dev:worker": "npm run dev -w worker",
    "deploy:pages": "wrangler pages deploy frontend/dist --project-name=dashboard-chat",
    "test:e2e": "playwright test --config=e2e/config/local.config.ts",
    "test:e2e:local": "playwright test --config=e2e/config/local.config.ts",
    "test:e2e:prod": "playwright test --config=e2e/config/production.config.ts",
    "test:e2e:ui": "playwright test --ui --config=e2e/config/local.config.ts",
    "test:e2e:debug": "playwright test --debug --config=e2e/config/local.config.ts",
    "test:frontend": "npm run test:run -w frontend",
    "test:worker": "npm run test:run -w worker",
    "build": "turbo run build",
    "test": "turbo run test:run",
    "test:all": "turbo run test:run && cd backend && uv run pytest",
    "test:backend": "cd backend && uv run pytest"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.2.3",
    "tsx": "^4.19.0",
    "turbo": "^2.4.0",
    "typescript": "^5.6.3",
    "vitest": "^4.0.15"
  }
}
