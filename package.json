{
  "name": "dashboard-chat",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:worker": "wrangler dev",
    "deploy:worker": "wrangler deploy",
    "deploy:pages": "wrangler pages deploy frontend/dist --project-name=dashboard-chat",
    "test:e2e": "playwright test --config=e2e/config/local.config.ts",
    "test:e2e:local": "playwright test --config=e2e/config/local.config.ts",
    "test:e2e:prod": "playwright test --config=e2e/config/production.config.ts",
    "test:e2e:ui": "playwright test --ui --config=e2e/config/local.config.ts",
    "test:e2e:debug": "playwright test --debug --config=e2e/config/local.config.ts",
    "test:worker": "vitest run --config worker/vitest.config.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@playwright/test": "^1.57.0",
    "typescript": "^5.6.3",
    "vitest": "^4.0.15",
    "wrangler": "^4.56.0"
  }
}
