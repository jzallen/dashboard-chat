{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "baseUrl": "..",
    "paths": {
      "@/raqb": ["frontend/src/lib/raqb"]
    }
  },
  "include": ["*.ts", "../frontend/src/lib/chat/**/*.ts"]
}
